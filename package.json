{
  "name": "openblueprint",
  "version": "0.1.0",
  "description": "AI-Powered Agent Generation & Management Platform",
  "main": "./src/server/index.ts",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:ui": "vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "openai": "^6.39.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.0.0",
    "sql.js": "^1.14.1",
    "ws": "^8.21.0",
    "zod": "^4.2.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  }
}
